# ============================================================
# Interview Helper — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ----- AI Provider (choose one or more) ---------------------
# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Google Gemini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-pro

# Ollama (local, no key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Primary provider: openai | claude | gemini | ollama
AI_PROVIDER=openai

# ----- Speech Recognition -----------------------------------
# Model: tiny, base, small, medium, large-v3
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
# Force language (leave blank for auto-detect)
WHISPER_LANGUAGE=en

# Audio settings
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SECONDS=3
AUDIO_SILENCE_THRESHOLD=0.01
AUDIO_PAUSE_DURATION=1.5

# ----- OCR -------------------------------------------------
OCR_ENGINE=tesseract
# Path to tesseract binary (Windows example below)
TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe

# ----- Database --------------------------------------------
DB_PATH=~/.interview_helper/history.db
CACHE_MAX_SIZE=500

# ----- UI --------------------------------------------------
DEFAULT_THEME=dark
DEFAULT_OPACITY=0.92
WINDOW_WIDTH=540
WINDOW_HEIGHT=750
FONT_SIZE=13

# ----- Logging ---------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=~/.interview_helper/app.log

# ----- Resume (optional, for personalized answers) ---------
RESUME_PATH=
